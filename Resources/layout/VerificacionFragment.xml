<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainContainerVerificacion"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

		<!-- Panel superior -->
		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="10dp">

			<!-- Total Acumulado -->
			<LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="6dp">

				<TextView
                    android:id="@+id/txtTotalAcumulado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/totalAcumulado"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"
                    android:autoSizeTextType="uniform"
                    android:singleLine="true" />

				<TextView
                    android:id="@+id/txtNumTotalAcumulado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_counter"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:autoSizeTextType="uniform"
                    android:padding="4dp"
                    android:singleLine="true" />

			</LinearLayout>

			<!-- Total Cajas Leídas -->
			<LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="6dp">

				<TextView
                    android:id="@+id/txtTotalCajasLeidas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/totalCajasLeidas"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"
                    android:autoSizeTextType="uniform"
                    android:singleLine="true" />

				<TextView
                    android:id="@+id/txtNumTotalCajas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_counter"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:autoSizeTextType="uniform"
                    android:padding="4dp"
                    android:singleLine="true" />

			</LinearLayout>

		</LinearLayout>

		<!-- GridView QR -->
		<GridView
            android:id="@+id/gvleidoVerificacion"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:numColumns="1"
            android:columnWidth="150dp"
            android:horizontalSpacing="10dp"
            android:verticalSpacing="10dp"
            android:stretchMode="columnWidth"
            android:smoothScrollbar="true"
            android:listSelector="@drawable/layerdraw"
            android:drawSelectorOnTop="false"
            android:padding="6dp"
            android:background="@drawable/gv_background" />

	</LinearLayout>

</FrameLayout>